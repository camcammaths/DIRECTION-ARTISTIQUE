function genererBrevet(){
  const chip=document.querySelector('.duree-chip.sel');
  const mins=chip?parseInt(chip.dataset.mins):120;
  const allNotions=!!document.querySelector('.notion-chip-g.all-chip.sel');
  const notions=[];
  if(!allNotions)document.querySelectorAll('.notion-chip-g.sel:not(.all-chip)').forEach(c=>notions.push(c.dataset.notion));
  const mode=(document.querySelector('.corr-chip-g.sel')||{dataset:{mode:'question'}}).dataset.mode;

  // Filtrer les exercices selon les notions sélectionnées
  let pool=EXERCICES_DB.filter(e=>allNotions||notions.indexOf(e.notion)!==-1);
  if(!pool.length)pool=EXERCICES_DB.slice();

  // Mélanger et prendre selon la durée
  pool=pool.slice().sort(()=>Math.random()-.5);
  const nbEx=mins>=120?Math.min(5,pool.length):mins>=90?Math.min(4,pool.length):mins>=60?Math.min(3,pool.length):mins>=30?Math.min(2,pool.length):1;
  const selected=pool.slice(0,nbEx).map((e,i)=>Object.assign({},e,{numero:i+1}));

  if(!selected.length){showToast('Aucun exercice disponible pour ces critères.');return;}

  // Stocker et afficher la page brevet
  window._brevetMode=mode;
  window._brevetData=selected;
  window._scores={};
  afficherPageBrevet(selected,mode);
  showToast('✓ Brevet généré — '+(chip?chip.querySelector('span').textContent:'2h'));
}

