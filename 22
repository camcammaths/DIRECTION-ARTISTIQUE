const examDate=new Date('2026-06-27T08:00:00');
function padCD(n){return String(n).padStart(2,'0');}
function tickCD(){
  const diff=examDate-new Date();
  if(diff<=0){document.getElementById('days-num').textContent='0';['cd-j','cd-h','cd-m','cd-s'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='00';});return;}
  const totalSec=Math.floor(diff/1000),j=Math.floor(totalSec/86400),h=Math.floor((totalSec%86400)/3600),m=Math.floor((totalSec%3600)/60),s=totalSec%60;
  const dn=document.getElementById('days-num');if(dn)dn.textContent=j;
  const cj=document.getElementById('cd-j');if(cj)cj.textContent=padCD(j);
  const ch=document.getElementById('cd-h');if(ch)ch.textContent=padCD(h);
  const cm=document.getElementById('cd-m');if(cm)cm.textContent=padCD(m);
  const cs=document.getElementById('cd-s');if(cs)cs.textContent=padCD(s);
}
