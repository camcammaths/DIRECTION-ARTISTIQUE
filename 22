<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prépa Brevet — Maths</title>
<style>
:root{--blue:#0021BC;--blue-lt:#BDD4E7;--orange:#EE6E34;--rose:#D0A6C6;--bg:#EDEEF0;--white:#FFFFFF;--ink:rgb(25,8,6);--muted:#8A8DAA;--green:#22C55E;--red:#EF4444;--fd:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--ink);font-family:var(--fd);-webkit-font-smoothing:antialiased}

/* NAV */
.nav{display:flex;justify-content:space-between;align-items:flex-start;padding:28px 48px 0;z-index:10;position:relative}
.logo{cursor:pointer;text-decoration:none;color:inherit}
.logo-top{font-size:13px;color:var(--ink);display:block}
.logo-bot{font-size:36px;font-weight:800;letter-spacing:-.04em;line-height:.9;text-transform:uppercase;display:block}
.logo-bot span{color:var(--blue)}
.nav-r{display:flex;align-items:center;gap:32px}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links li{font-size:14px;opacity:.6;cursor:pointer;transition:opacity .15s}
.nav-links li:hover{opacity:1}
.nav-links li.on{opacity:1;font-weight:500}
.nav-links li.on-orange{opacity:1;font-weight:600;color:var(--orange)}
.cta{font-size:13px;font-weight:600;background:var(--blue);color:#fff;padding:11px 24px;border-radius:100px;border:none;cursor:pointer;transition:opacity .15s;text-decoration:none;display:inline-flex;align-items:center}
.cta:hover{opacity:.85}

body > nav.nav{display:flex}
.page{display:none !important}
.page.active{display:block !important}
#page-accueil.active{display:block !important}
#page-parcours.active{display:flex !important;flex-direction:column;height:calc(100vh - 93px);overflow:hidden}
#page-abonnement.active{display:flex !important;flex-direction:column}
#page-planning.active{display:flex !important;flex-direction:column;height:calc(100vh - 93px);overflow:hidden}
#page-generer.active{display:flex !important;flex-direction:column;height:calc(100vh - 93px);overflow:hidden}

/* SPLASH ACCUEIL */
.splash{width:100%;height:calc(100vh - 93px);position:relative;overflow:hidden;display:flex;flex-direction:column;background:var(--bg);}
.splash::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(0,33,188,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,33,188,.04) 1px,transparent 1px);background-size:72px 72px;pointer-events:none;z-index:0;}
.splash-body{flex:1;display:grid;grid-template-columns:1fr 1fr;padding:32px 48px 40px;gap:48px;align-items:stretch;position:relative;z-index:2;min-height:0;}
.splash-left{display:flex;flex-direction:column;justify-content:space-between;padding-right:48px;}
.splash-eyebrow{font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--orange);display:flex;align-items:center;gap:10px;}
.splash-eyebrow::before{content:'';width:20px;height:2px;background:var(--orange);border-radius:2px;display:inline-block}
.splash-title{font-family:var(--fd);font-size:clamp(32px,4.5vw,72px);font-weight:500;line-height:.95;letter-spacing:-.04em;text-transform:lowercase;}
.splash-title .accent{color:var(--blue)}
.splash-ctas{display:flex;gap:12px;}
.splash-right{display:flex;flex-direction:column;justify-content:space-between;gap:20px;min-height:0;}
.countdown-label{font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
.countdown-digits{display:flex;gap:10px;align-items:flex-end;}
.cd-unit{display:flex;flex-direction:column;align-items:center;gap:4px;}
.cd-num{font-family:var(--fd);font-size:clamp(22px,3vw,48px);font-weight:500;letter-spacing:-.04em;line-height:1;color:var(--blue);background:var(--white);border-radius:10px;padding:8px 14px;min-width:52px;text-align:center;}
.cd-sep{font-family:var(--fd);font-size:clamp(18px,2.2vw,36px);font-weight:300;color:var(--muted);margin-bottom:8px;line-height:1;}
.cd-lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;}
.exam-card{background:var(--white);border-radius:16px;padding:18px 22px;display:flex;flex-direction:column;gap:12px;flex-shrink:0;}
.exam-card-top{display:flex;justify-content:space-between;align-items:center;}
.exam-card-title{font-family:var(--fd);font-size:15px;font-weight:500;letter-spacing:-.02em;text-transform:lowercase;}
.exam-badge{font-size:10px;font-weight:600;padding:4px 12px;border-radius:100px;background:#FFF0E8;border:1.5px solid var(--orange);color:var(--orange);}
.exam-progress-label{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:6px;}
.exam-bar{height:6px;background:rgba(0,0,0,.07);border-radius:100px;overflow:hidden;}
.exam-bar-fill{height:100%;background:var(--orange);border-radius:100px;width:52%;}
.exam-parts{display:flex;gap:8px;}
.exam-part{flex:1;background:#F4F5F8;border-radius:8px;padding:8px 10px;font-size:11px;color:var(--muted);}
.exam-part strong{display:block;font-family:var(--fd);font-size:14px;font-weight:500;color:var(--ink);letter-spacing:-.02em;margin-bottom:2px;}
.scroll-hint{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;z-index:10;cursor:pointer;opacity:.45;transition:opacity .2s;}
.scroll-hint:hover{opacity:.9}
.scroll-hint span{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.scroll-arrow{width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(0,0,0,.15);display:flex;align-items:center;justify-content:center;animation:bounce 2s infinite;}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

/* PLANNING */
.planning-hero{padding:16px 48px 10px;display:flex;align-items:center;gap:24px;flex-shrink:0}
.planning-hero h1{font-family:var(--fd);font-size:clamp(24px,2.5vw,36px);font-weight:500;line-height:1;letter-spacing:-.04em;text-transform:lowercase}
.planning-hero h1 span{color:var(--blue)}
.planning-wrap{padding:0 28px;flex:1;display:flex;flex-direction:column;overflow:hidden}
.week-nav-label{font-family:var(--fd);font-size:14px;font-weight:500;letter-spacing:-.03em;text-transform:lowercase;min-width:160px;text-align:center}
.week-nav-btn{width:26px;height:26px;border-radius:6px;border:1.5px solid rgba(0,0,0,.1);background:transparent;cursor:pointer;font-size:12px;color:var(--muted);transition:all .15s;display:flex;align-items:center;justify-content:center}
.week-nav-btn:hover{border-color:var(--blue);color:var(--blue)}
.week-stats-row{display:flex;gap:2px}
.week-stat{background:var(--white);padding:6px 14px;text-align:center}
.week-stat:first-child{border-radius:8px 0 0 8px}
.week-stat:last-child{border-radius:0 8px 8px 0}
.week-stat-n{font-family:var(--fd);font-size:16px;font-weight:500;letter-spacing:-.04em;color:var(--blue)}
.week-stat-l{font-size:8px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:1px}
.week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;flex:1}
.day-col{display:flex;flex-direction:column;overflow:hidden}
.day-header{padding:7px 8px 6px;background:var(--white);text-align:center;flex-shrink:0}
.day-header.today{background:var(--blue)}
.day-header:first-child{border-radius:12px 0 0 0}
.day-header:last-child{border-radius:0 12px 0 0}
.day-name{font-size:8px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.day-header.today .day-name{color:rgba(255,255,255,.6)}
.day-num{font-family:var(--fd);font-size:18px;font-weight:500;letter-spacing:-.04em;line-height:1;margin-top:2px;color:var(--ink)}
.day-header.today .day-num{color:#fff}
.day-body{background:var(--white);flex:1;padding:5px;border-top:1px solid rgba(0,0,0,.05);position:relative;overflow-y:auto}
.day-col:last-child .day-body{border-radius:0 0 12px 0}
.day-col:first-child .day-body{border-radius:0 0 0 12px}
.day-body.past{opacity:.6}
.add-slot{width:100%;background:none;border:1.5px dashed rgba(0,0,0,.1);border-radius:6px;padding:5px;cursor:pointer;font-size:16px;color:var(--muted);opacity:.4;transition:opacity .15s;display:flex;align-items:center;justify-content:center;margin-top:3px}
.add-slot:hover{opacity:.8;border-color:var(--blue)}
.task-pill{border-radius:6px;padding:4px 7px;margin-bottom:3px;font-size:9px;line-height:1.3;font-weight:500;position:relative;cursor:pointer}
.task-pill.done{opacity:.45;text-decoration:line-through}
.task-pill.t-revision{background:#EEF2FF;color:var(--blue)}
.task-pill.t-entrainement{background:#FFF0E8;color:var(--orange)}
.task-pill.t-brevet{background:#EDFBF0;color:#166534}
.task-pill.t-repos{background:rgba(0,0,0,.05);color:var(--muted)}
.task-check{float:right;width:11px;height:11px;border-radius:50%;border:1.5px solid currentColor;display:inline-flex;align-items:center;justify-content:center;font-size:7px;margin-left:3px;margin-top:1px;cursor:pointer;flex-shrink:0}
.task-pill.done .task-check{background:currentColor;color:#fff}
.task-del{position:absolute;top:-3px;right:-3px;width:12px;height:12px;border-radius:50%;background:var(--red);color:#fff;font-size:7px;display:none;align-items:center;justify-content:center;cursor:pointer;border:none;line-height:1}
.task-pill:hover .task-del{display:flex}
.task-duration{display:block;font-size:8px;font-weight:400;opacity:.6;margin-top:1px}
.plan-ia-card{background:var(--white);border-radius:14px;padding:14px 18px;margin-top:8px;flex-shrink:0}
.type-select{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
.type-opt{font-size:11px;font-weight:600;padding:6px 14px;border-radius:100px;border:1.5px solid rgba(0,0,0,.1);background:transparent;cursor:pointer;color:var(--muted);transition:all .15s;text-transform:lowercase}
.type-opt:hover{border-color:var(--blue);color:var(--blue)}
.type-opt.sel.t-revision{background:#EEF2FF;border-color:var(--blue);color:var(--blue)}
.type-opt.sel.t-entrainement{background:#FFF0E8;border-color:var(--orange);color:var(--orange)}
.type-opt.sel.t-brevet{background:#EDFBF0;border-color:var(--green);color:#166534}
.type-opt.sel.t-repos{background:rgba(0,0,0,.06);border-color:var(--muted);color:var(--muted)}
.partie-label{display:block;margin:18px 0 10px;padding:8px 14px;background:rgba(0,33,188,.06);border-radius:8px;border-left:3px solid var(--blue);font-weight:700;font-size:13px;color:var(--blue);letter-spacing:.03em;text-transform:uppercase}
.partie-label.orange{background:rgba(238,110,52,.06);border-color:var(--orange);color:var(--orange)}

/* ACCUEIL */
.divider{height:1px;background:rgba(0,0,0,.1);margin:0 48px}
.eyebrow{font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--orange);display:flex;align-items:center;gap:10px}
.eyebrow::before{content:'';width:20px;height:2px;background:var(--orange);border-radius:2px;display:inline-block}
.btn{display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:600;padding:13px 28px;border-radius:100px;cursor:pointer;border:none;text-transform:lowercase;transition:opacity .15s;text-decoration:none}
.btn:hover{opacity:.85}
.btn-blue{background:var(--blue);color:#fff}
.btn-ghost{background:transparent;color:var(--ink);border:1.5px solid rgba(0,0,0,.15);padding:12px 26px}
.acc-ctag{font-size:10px;font-weight:500;padding:4px 12px;border-radius:100px;border:1.5px solid rgba(0,0,0,.1);color:var(--muted);background:transparent}
.acc-ctag.b{background:#EEF2FF;border-color:var(--blue);color:var(--blue)}
.acc-ctag.o{background:#FFF0E8;border-color:var(--orange);color:var(--orange)}
.acc-ctag.r{background:#F9F0F7;border-color:var(--rose);color:#8B5A7A}
.stats-strip{display:grid;grid-template-columns:repeat(4,1fr);padding:0 48px}
.stat{padding:40px 32px;border-right:1px solid rgba(0,0,0,.08)}
.stat:last-child{border-right:none}
.stat-n{font-size:64px;font-weight:500;letter-spacing:-.04em;line-height:1;text-transform:lowercase;margin-bottom:8px}
.stat-l{font-size:13px;color:var(--muted);font-weight:300;line-height:1.5;max-width:180px}
.sec{padding:56px 48px;border-top:1px solid rgba(0,0,0,.08)}
.sec-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:36px}
.sec-title{font-size:clamp(28px,3.5vw,48px);font-weight:500;text-transform:lowercase;letter-spacing:-.03em;line-height:1}
.see-all{font-size:13px;font-weight:500;color:var(--blue);cursor:pointer;text-decoration:none}
.chap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.chap-card{background:var(--white);padding:28px;cursor:pointer;transition:background .15s}
.chap-card:hover{background:#F4F5F8}
.chap-card:nth-child(1){border-radius:16px 0 0 0}
.chap-card:nth-child(3){border-radius:0 16px 0 0}
.chap-card:nth-child(4){margin-top:2px}
.chap-card:nth-child(5){margin-top:2px}
.chap-card:nth-child(6){border-radius:0 0 16px 0;margin-top:2px}
.chap-num{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.chap-title{font-size:18px;font-weight:500;text-transform:lowercase;letter-spacing:-.02em;margin-bottom:4px}
.chap-meta{font-size:12px;color:var(--muted);font-weight:300;margin-bottom:16px}
.chap-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.bar-wrap{display:flex;align-items:center;gap:10px}
.bar{flex:1;height:5px;background:rgba(0,0,0,.07);border-radius:100px;overflow:hidden}
.bar-fill{height:100%;border-radius:100px}
.bar-pct{font-family:'Courier New',monospace;font-size:11px;font-weight:700;white-space:nowrap}
.footer-top{padding:48px 48px 36px;display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:40px;border-top:1px solid rgba(0,0,0,.08)}
.footer-logo-bot{font-size:26px;font-weight:800;letter-spacing:-.04em;text-transform:uppercase;line-height:.95;margin-bottom:12px}
.footer-logo-bot span{color:var(--blue)}
.footer-desc{font-size:12px;color:var(--muted);font-weight:300;line-height:1.65}
.footer-col-title{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-links li{font-size:13px;color:rgba(0,0,0,.45);cursor:pointer;font-weight:300}
.footer-links li:hover{color:var(--ink)}
.footer-email-wrap{padding:0 48px;border-top:1px solid rgba(0,0,0,.08);display:flex;align-items:center}
.footer-email{font-size:clamp(24px,4vw,56px);font-weight:500;color:var(--ink);letter-spacing:-.04em;text-transform:lowercase;padding:28px 0;text-decoration:none;transition:color .15s}
.footer-email:hover{color:var(--blue)}
.footer-bar{background:var(--blue);padding:16px 48px;display:flex;justify-content:space-between;align-items:center}
.footer-bar-links{display:flex;gap:40px}
.footer-bar-links a{font-size:13px;font-weight:500;color:rgba(255,255,255,.7);text-decoration:none;cursor:pointer}
.footer-bar-links a:hover{color:#fff}
.footer-bar-copy{font-size:12px;color:rgba(255,255,255,.35)}

/* ABONNEMENT */
#page-abonnement{min-height:calc(100vh - 93px)}
.abo-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:24px 48px 32px}
.abo-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;width:100%;max-width:1100px}
.col-hero{display:flex;flex-direction:column;justify-content:space-between;background:var(--white);border-radius:24px;padding:32px}
.abo-eyebrow{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--orange);display:flex;align-items:center;gap:8px;margin-bottom:16px}
.abo-eyebrow::before{content:'';width:12px;height:2px;background:var(--orange);border-radius:2px;display:inline-block}
.hero-title{font-size:clamp(36px,4vw,64px);font-weight:500;line-height:.92;letter-spacing:-.05em;text-transform:lowercase;margin-bottom:16px}
.hero-sub{font-size:13px;color:var(--muted);font-weight:300;line-height:1.6;border-left:3px solid var(--blue-lt);padding-left:14px;margin-bottom:28px}
.abo-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.abo-stat{background:var(--bg);border-radius:12px;padding:14px 16px}
.abo-stat-n{font-size:clamp(24px,2.5vw,36px);font-weight:500;letter-spacing:-.04em;line-height:1;margin-bottom:2px}
.abo-stat-l{font-size:11px;color:var(--muted);font-weight:300;line-height:1.3}
.col-plan{border-radius:24px;padding:28px;display:flex;flex-direction:column}
.col-free{background:var(--white)}
.col-pro{background:var(--blue)}
.plan-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.plan-name{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase}
.col-free .plan-name{color:var(--muted)}
.col-pro .plan-name{color:rgba(255,255,255,.45)}
.pop{background:var(--orange);color:#fff;font-size:10px;font-weight:700;padding:4px 12px;border-radius:100px;text-transform:uppercase;letter-spacing:.05em}
.tog-row{display:flex;gap:6px;margin-bottom:10px}
.tog-btn{font-size:11px;font-weight:600;padding:5px 13px;border-radius:100px;border:none;cursor:pointer;transition:background .15s,color .15s}
.price-area{margin-bottom:10px}
.price-row{display:flex;align-items:baseline;gap:4px}
.price-num{font-size:clamp(36px,4vw,60px);font-weight:500;letter-spacing:-.05em;line-height:1}
.col-free .price-num{color:var(--ink)}
.col-pro .price-num{color:#fff}
.price-per{font-size:13px}
.col-free .price-per{color:var(--muted)}
.col-pro .price-per{color:rgba(255,255,255,.45)}
.price-note{font-size:11px;font-weight:300;margin-top:3px}
.col-free .price-note{color:var(--muted)}
.col-pro .price-note{color:rgba(255,255,255,.35)}
.plan-divider{height:1px;margin:14px 0}
.col-free .plan-divider{background:rgba(0,0,0,.07)}
.col-pro .plan-divider{background:rgba(255,255,255,.12)}
.feats{display:flex;flex-direction:column;gap:9px;flex:1;margin-bottom:18px}
.feat{display:flex;align-items:center;gap:9px;font-size:13px}
.dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}
.col-free .dot.on{background:#EEF2FF;color:var(--blue)}
.col-free .dot.off{background:rgba(0,0,0,.05);color:var(--muted);opacity:.3}
.col-pro .dot.on{background:rgba(255,255,255,.15);color:#fff}
.col-free .feat.off>span:last-child{opacity:.3}
.plan-btn{width:100%;font-family:var(--fd);font-size:13px;font-weight:600;border-radius:100px;padding:14px;cursor:pointer;text-transform:lowercase;border:none;margin-top:auto;transition:opacity .15s}
.plan-btn:hover{opacity:.85}
.col-free .plan-btn{background:var(--bg);color:var(--ink)}
.col-pro .plan-btn{background:var(--orange);color:#fff}
.abo-footer{background:var(--blue);padding:14px 48px;display:flex;justify-content:space-between;align-items:center}
.abo-footer-links{display:flex;gap:32px}
.abo-footer-links a{font-size:13px;font-weight:500;color:rgba(255,255,255,.6);text-decoration:none;cursor:pointer}
.abo-footer-copy{font-size:12px;color:rgba(255,255,255,.3)}

/* PARCOURS */
.p-divider{height:1px;background:rgba(0,0,0,.1)}
.p-body{flex:1;overflow:hidden;padding:10px 14px;display:grid;grid-template-columns:200px 1fr 220px;grid-template-rows:auto 1fr;gap:8px}
.panel{background:var(--white);border-radius:12px;overflow:hidden;display:flex;flex-direction:column}
.panel-head{padding:10px 14px 8px;border-bottom:1px solid rgba(0,0,0,.06);flex-shrink:0}
.panel-label{font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:2px}
.panel-title{font-size:14px;font-weight:500;text-transform:lowercase;letter-spacing:-.02em;display:block}
.panel-body{flex:1;overflow:hidden;padding:10px 14px}
.panel-body.scroll{overflow-y:auto}
.panel-body.scroll::-webkit-scrollbar{width:3px}
.panel-body.scroll::-webkit-scrollbar-thumb{background:rgba(0,0,0,.1);border-radius:100px}
.col-left{grid-column:1;grid-row:1/3;display:flex;flex-direction:column;gap:8px}
.cd-label{font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:4px}
.cd-note{font-size:52px;font-weight:500;letter-spacing:-.06em;line-height:1}
.cd-sub{font-size:10px;color:rgba(255,255,255,.45);font-weight:300;margin-top:2px;margin-bottom:10px}
