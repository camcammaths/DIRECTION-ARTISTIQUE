            <div style="font-size:11px;font-weight:700;color:var(--blue);margin-bottom:4px">${l}</div>
            <div style="font-size:14px">${q.options[li]}</div>
          </button>`;
        });
        html+=`</div><input type="hidden" id="ans-${ei}-${qi}" value="">`;
      } else {
        html+=`<textarea style="width:100%;font-size:14px;color:var(--ink);background:#FAFAFA;border:1.5px solid rgba(0,0,0,.08);border-radius:10px;padding:12px 14px;resize:vertical;line-height:1.6;font-family:inherit" rows="2" id="ans-${ei}-${qi}" placeholder="Ta réponse…"></textarea>`;
      }
      if(mode==='question'){
        html+=`<button onclick="corrigerQOv(${ei},${qi})" id="corr-btn-${ei}-${qi}" style="margin-top:8px;font-size:12px;font-weight:600;padding:7px 18px;border-radius:100px;border:none;background:var(--blue);color:#fff;cursor:pointer">corriger →</button>`;
      }
      html+=`<div id="fb-${ei}-${qi}" style="display:none;margin-top:8px;padding:10px 14px;border-radius:10px;font-size:13px"></div></div>`;
    });
    html+=`</div>`;
  });
  if(mode==='fin'){
    html+=`<button onclick="corrigerToutOv()" style="font-family:var(--fd);font-size:14px;font-weight:600;padding:14px 32px;border-radius:100px;border:none;background:var(--blue);color:#fff;cursor:pointer;margin-top:8px">corriger mon brevet →</button>`;
  }
  html+=`</div>`; // ferme le div padding content
  overlay.innerHTML=html;
  // Init minuteur
  window._btimerSecs=totalMins*60;
  window._btimerTotal=totalMins*60;
  window._btimerRunning=false;
  window._btimerInterval=null;
  _updateBrevetTimerDisplay();
}

function _updateBrevetTimerDisplay(){
  const s=Math.max(0,window._btimerSecs||0);
  const h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=s%60;
  const str=h>0?`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`:`${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  const el=document.getElementById('brevet-timer-display');
  if(!el)return;
  if(s<=300){el.style.color='var(--red)';}
  else if(s<=window._btimerTotal*0.25){el.style.color='var(--orange)';}
  else{el.style.color='var(--blue)';}
  el.textContent=str;
}

function toggleBrevetTimer(){
  const btn=document.getElementById('brevet-timer-btn');
  const icon=document.getElementById('brevet-timer-icon');
  if(window._btimerRunning){
    clearInterval(window._btimerInterval);
    window._btimerRunning=false;
    if(btn)btn.innerHTML='<span id="brevet-timer-icon">▶</span> démarrer';
  } else {
    if(window._btimerSecs<=0)return;
    window._btimerRunning=true;
    if(btn)btn.innerHTML='<span id="brevet-timer-icon">⏸</span> pause';
    window._btimerInterval=setInterval(()=>{
      window._btimerSecs--;
      _updateBrevetTimerDisplay();
      if(window._btimerSecs<=0){
        clearInterval(window._btimerInterval);
        window._btimerRunning=false;
        const b=document.getElementById('brevet-timer-btn');
        if(b)b.innerHTML='<span>⏱</span> terminé';
        const d=document.getElementById('brevet-timer-display');
        if(d){d.textContent='00:00';d.style.color='var(--red)';}
      }
    },1000);
  }
}

function resetBrevetTimer(){
  clearInterval(window._btimerInterval);
  window._btimerRunning=false;
  window._btimerSecs=window._btimerTotal||7200;
  _updateBrevetTimerDisplay();
  const btn=document.getElementById('brevet-timer-btn');
  if(btn)btn.innerHTML='<span id="brevet-timer-icon">▶</span> démarrer';
  const d=document.getElementById('brevet-timer-display');
  if(d)d.style.color='var(--blue)';
}

function fermerBrevet(){
  clearInterval(window._btimerInterval);
  window._btimerRunning=false;
  const ov=document.getElementById('brevet-overlay');
  if(ov)ov.remove();
}

function selQcmOv(ei,qi,lettre){
  const fb=document.getElementById(`fb-${ei}-${qi}`);
  if(fb&&fb.style.display==='block')return;
  ['A','B','C','D'].forEach(l=>{const b=document.getElementById(`qcm-opt-${ei}-${qi}-${l}`);if(b){b.style.background='#FAFAFA';b.style.borderColor='rgba(0,0,0,.08)';}});
  const sel=document.getElementById(`qcm-opt-${ei}-${qi}-${lettre}`);
  if(sel){sel.style.background='#EEF2FF';sel.style.borderColor='var(--blue)';}
  const inp=document.getElementById(`ans-${ei}-${qi}`);
  if(inp)inp.value=lettre;
  if(window._brevetMode==='question')corrigerQOv(ei,qi);
}

async function corrigerQOv(ei,qi){
  const q=window._brevetData[ei].questions[qi];
  const ans=document.getElementById(`ans-${ei}-${qi}`).value.trim();
  const fb=document.getElementById(`fb-${ei}-${qi}`);
  const btn=document.getElementById(`corr-btn-${ei}-${qi}`);
  if(!ans){fb.style.display='block';fb.style.background='#FEF2F2';fb.innerHTML='<strong>✗</strong> Écris une réponse avant de corriger.';return;}
  if(btn){btn.disabled=true;btn.textContent='correction…';}
  // Vérifier si QCM
  if(q.options&&q.options.length){
    const match=q.reponse.match(/R.ponse\s*([A-Z])/i)||q.reponse.match(/^([A-Z])\s*[-—]/);
    const correct=match?match[1].toUpperCase():null;
    const ok=correct&&ans===correct;
    ['A','B','C','D'].forEach(l=>{
      const b=document.getElementById(`qcm-opt-${ei}-${qi}-${l}`);
      if(!b)return;b.disabled=true;
      if(l===ans&&l===correct)b.style.background='#EDFBF0';
      else if(l===ans)b.style.background='#FEF2F2';
      else if(l===correct)b.style.background='#EDFBF0';
    });
    const pts=ok?q.points:0;
    showFbOv(ei,qi,pts,q.points,ok?'ok':'ko',q.reponse);
    return;
  }
  // Correction IA pour les questions ouvertes — critères DNB
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      model:'claude-haiku-4-5-20251001',
      max_tokens:400,
      system:`Tu es un correcteur officiel du DNB (brevet des collèges), mathématiques. Tu appliques les critères nationaux : valorise la démarche même si le résultat est faux, accepte les méthodes alternatives correctes, accorde des points partiels si la démarche est partiellement juste. Feedback bienveillant et pédagogique en 1-2 phrases. Réponds UNIQUEMENT en JSON sans markdown.`,
      messages:[{role:'user',content:`Exercice: "${window._brevetData[ei].titre}" — Notion: ${window._brevetData[ei].notion}\nQuestion ${q.id} (${q.points} pt${q.points>1?'s':''}): "${q.texte.replace(/\n/g,' ')}"\nRéponse attendue: "${q.reponse}"\nRéponse de l'élève: "${ans}"\n\nJSON: {"pts":X,"verdict":"ok|bof|ko","correction":"feedback"}`}]
    })});
    const d=await r.json();
    const res=JSON.parse(d.content[0].text.trim().replace(/```json|```/g,'').trim());
    showFbOv(ei,qi,Math.min(res.pts,q.points),q.points,res.verdict,res.correction);
  }catch(e){
    if(btn){btn.disabled=false;btn.textContent='corriger →';}
    showToast('Erreur de correction — réessaie');
  }
}

function showFbOv(ei,qi,pts,max,verdict,texte){
  const fb=document.getElementById(`fb-${ei}-${qi}`);
  const btn=document.getElementById(`corr-btn-${ei}-${qi}`);
  const badge=document.getElementById(`pts-badge-${ei}-${qi}`);
  const colors={ok:['#EDFBF0','#166534'],bof:['#FFFBEB','#92400E'],ko:['#FEF2F2','#991B1B']};
  const [bg,fg]=colors[verdict]||colors.ko;
  const icon=verdict==='ok'?'✓':verdict==='bof'?'~':'✗';
  fb.style.display='block';fb.style.background=bg;fb.style.color=fg;
  fb.innerHTML=`<strong>${icon} ${pts}/${max} pt${max>1?'s':''}</strong> — ${texte}`;
  if(badge){badge.style.background=bg;badge.style.color=fg;badge.textContent=`${pts}/${max} pt${max>1?'s':''}`;}
  if(btn)btn.style.display='none';
  if(!window._scores)window._scores={};
  if(!window._scores[ei])window._scores[ei]={};
  window._scores[ei][qi]=pts;
}

async function corrigerToutOv(){
  const ex=window._brevetData;
  const btn=document.querySelector('#brevet-overlay button[onclick="corrigerToutOv()"]');
  if(btn){btn.textContent='correction en cours…';btn.disabled=true;btn.style.opacity='.5';}

  // Séparer QCM (correction instantanée) et questions ouvertes
  const qcmList=[], openList=[];
  ex.forEach((e,ei)=>{
    e.questions.forEach((q,qi)=>{
      if(q.options&&q.options.length) qcmList.push({ei,qi});
      else openList.push({ei,qi,e,q});
    });
  });

  // Corriger les QCM instantanément
  qcmList.forEach(({ei,qi})=>{
    const q=ex[ei].questions[qi];
    const ans=document.getElementById(`ans-${ei}-${qi}`)?.value.trim()||'';
    const match=q.reponse.match(/R[ée]ponse\s*([A-Z])/i)||q.reponse.match(/^([A-Z])\s*[-—]/);
    const correct=match?match[1].toUpperCase():null;
    const ok=correct&&ans===correct;
    ['A','B','C','D'].forEach(l=>{
      const b=document.getElementById(`qcm-opt-${ei}-${qi}-${l}`);
      if(!b)return;b.disabled=true;
      if(l===ans&&l===correct)b.style.background='#EDFBF0';
      else if(l===ans&&l!==correct)b.style.background='#FEF2F2';
      else if(l===correct)b.style.background='#EDFBF0';
    });
    showFbOv(ei,qi,ok?q.points:0,q.points,ok?'ok':'ko',ok?'Bonne réponse. ✓':`La bonne réponse était ${correct||'?'}. ${q.reponse}`);
  });

  // Corriger toutes les questions ouvertes en UN SEUL appel
  const openWithAnswers=openList.filter(({ei,qi})=>{
    const ans=document.getElementById(`ans-${ei}-${qi}`)?.value.trim()||'';
    return ans.length>0;
  });
  const emptyOpen=openList.filter(({ei,qi})=>{
    const ans=document.getElementById(`ans-${ei}-${qi}`)?.value.trim()||'';
    return ans.length===0;
  });
  emptyOpen.forEach(({ei,qi,q})=>showFbOv(ei,qi,0,q.points,'ko','Aucune réponse fournie.'));

  if(openWithAnswers.length>0){
    const questionsPayload=openWithAnswers.map(({ei,qi,e,q})=>({
      id:`${ei}-${qi}`,
      exercice:e.titre,
      notion:e.notion,
      question:q.texte.replace(/\n/g,' '),
      reponse_attendue:q.reponse,
      reponse_eleve:document.getElementById(`ans-${ei}-${qi}`)?.value.trim()||'',
      points_max:q.points
    }));

    const systemPrompt=`Tu es un correcteur officiel du Diplôme National du Brevet (DNB), mathématiques.
Tu appliques les critères nationaux de correction :
- Valorise la démarche même si le résultat final est faux (points partiels)
- Accepte les notations équivalentes et les méthodes alternatives correctes
- Vérifie la rigueur du raisonnement mathématique
- Pour les démonstrations : évalue l'argumentation logique et la justification
- Pour les calculs : accorde les points si la méthode est correcte même avec une erreur de calcul mineure
- Ton feedback est bienveillant, précis et pédagogique (1-2 phrases max)
- Tu réponds UNIQUEMENT en JSON, sans markdown, sans preamble.`;

    const userPrompt=`Corrige ces ${questionsPayload.length} question(s) de brevet DNB.
Pour chaque question, attribue les points selon les critères nationaux.

Questions à corriger :
${JSON.stringify(questionsPayload,null,2)}

Réponds avec ce JSON exact :
{"corrections":[{"id":"ei-qi","pts":X,"verdict":"ok|bof|ko","feedback":"explication courte et bienveillante"},...]}

verdict : "ok"=réponse correcte ou démarche complète, "bof"=démarche partiellement correcte ou erreur mineure, "ko"=réponse incorrecte ou absente`;

    try{
      const r=await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          model:'claude-haiku-4-5-20251001',
          max_tokens:1500,
          system:systemPrompt,
          messages:[{role:'user',content:userPrompt}]
        })
      });
      const d=await r.json();
      const txt=d.content[0].text.trim().replace(/```json|```/g,'').trim();
      const result=JSON.parse(txt);
      result.corrections.forEach(c=>{
        const [ei,qi]=c.id.split('-').map(Number);
        const q=ex[ei].questions[qi];
        showFbOv(ei,qi,Math.min(c.pts,q.points),q.points,c.verdict,c.feedback);
      });
    }catch(e){
      // Fallback question par question si erreur
      for(const {ei,qi} of openWithAnswers){
        await corrigerQOv(ei,qi);
      }
    }
  }

  afficherBilanFinal();
}

function afficherBilanFinal(){
  const ex=window._brevetData;
  let totalPts=0,totalEarned=0;
  const exScores=ex.map((e,ei)=>{
    const max=e.questions.reduce((a,q)=>a+q.points,0);
    const earned=Object.values((window._scores&&window._scores[ei])||{}).reduce((a,v)=>a+v,0);
    totalPts+=max;totalEarned+=earned;
    return {titre:e.titre,notion:e.notion,earned,max};
  });
  const note=totalPts>0?Math.round(totalEarned/totalPts*20*10)/10:0;
  const {label,cls}=getMention(note)||{label:'—',cls:''};

  // Récupérer les feedbacks de chaque question
  const corrections=[];
  ex.forEach((e,ei)=>{
    e.questions.forEach((q,qi)=>{
      const fb=document.getElementById(`fb-${ei}-${qi}`);
      const pts=window._scores&&window._scores[ei]?window._scores[ei][qi]||0:0;
      if(fb&&fb.style.display==='block'){
        corrections.push({exTitre:e.titre,qId:q.id,qTexte:q.texte.substring(0,60)+'…',pts,max:q.points,comment:fb.textContent.replace(/[✓~✗]\s*[\d,]+\/[\d,]+\s*pt[s]?\s*—?\s*/,'')});
      }
    });
  });

  // Construire le panneau bilan
  const bilan=document.createElement('div');
  bilan.id='brevet-bilan';
  bilan.style.cssText='max-width:880px;margin:28px auto 64px;padding:0 48px';

  const noteColor=note>=16?'var(--green)':note>=14?'var(--blue)':note>=10?'var(--orange)':'var(--red)';
  bilan.innerHTML=`
    <div style="background:var(--white);border-radius:18px;padding:28px;margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:20px;margin-bottom:24px">
        <div>
          <div style="font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:6px">résultat final</div>
          <div style="font-family:var(--fd);font-size:56px;font-weight:800;letter-spacing:-.04em;line-height:1;color:${noteColor}">${String(note).replace('.',',')} <span style="font-size:22px;font-weight:400;color:var(--muted)">/20</span></div>
          <div style="margin-top:10px"><span style="font-size:12px;font-weight:600;padding:5px 14px;border-radius:100px;background:#EEF2FF;color:var(--blue)">${label}</span></div>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;min-width:200px">
          ${exScores.map(s=>`
            <div style="display:flex;justify-content:space-between;align-items:center;gap:16px">
              <span style="font-size:12px;color:var(--muted);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${s.titre}</span>
              <div style="flex:1;height:4px;background:rgba(0,0,0,.07);border-radius:100px;overflow:hidden"><div style="height:100%;width:${s.max>0?Math.round(s.earned/s.max*100):0}%;background:${s.max>0&&s.earned/s.max>=0.8?'var(--green)':s.earned/s.max>=0.5?'var(--orange)':'var(--red)'};border-radius:100px"></div></div>
              <span style="font-size:12px;font-weight:600;color:var(--ink);white-space:nowrap">${s.earned}/${s.max} pts</span>
            </div>`).join('')}
          <div style="padding-top:8px;border-top:1px solid rgba(0,0,0,.07);display:flex;justify-content:space-between">
            <span style="font-size:12px;font-weight:600;color:var(--ink)">total</span>
            <span style="font-size:12px;font-weight:600;color:var(--ink)">${totalEarned}/${totalPts} pts</span>
          </div>
        </div>
      </div>
      ${corrections.length?`
      <div style="border-top:1px solid rgba(0,0,0,.07);padding-top:20px">
        <div style="font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:14px">commentaires détaillés</div>
        <div style="display:flex;flex-direction:column;gap:8px">
          ${corrections.map(c=>`<div style="background:#FAFAFA;border-radius:10px;padding:12px 14px;display:flex;gap:12px;align-items:flex-start">
            <span style="font-size:11px;font-weight:700;color:var(--blue);flex-shrink:0;padding-top:1px">${c.qId}.</span>
            <div style="flex:1;min-width:0">
              <div style="font-size:11px;color:var(--muted);margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.qTexte}</div>
              <div style="font-size:13px;color:var(--ink);line-height:1.5">${c.comment||'—'}</div>
            </div>
            <span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;white-space:nowrap;flex-shrink:0;background:${c.pts>=c.max?'#EDFBF0':c.pts>0?'#FFF0E8':'#FEF2F2'};color:${c.pts>=c.max?'#166534':c.pts>0?'#7C3D0E':'#991B1B'}">${c.pts}/${c.max} pt${c.max>1?'s':''}</span>
          </div>`).join('')}
