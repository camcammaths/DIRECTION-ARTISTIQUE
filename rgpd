<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mentions légales — Prépa Brevet</title>
<style>
:root {
  --blue:#0021BC;--blue-lt:#BDD4E7;--orange:#EE6E34;--rose:#D0A6C6;
  --bg:#EDEEF0;--white:#FFFFFF;--ink:rgb(25,8,6);--muted:#8A8DAA;
  --fd:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;
  --fb:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--ink);font-family:var(--fb);-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}

/* NAV */
.nav{display:flex;justify-content:space-between;align-items:flex-start;padding:28px 48px 0;z-index:10;position:relative}
.logo{cursor:pointer;text-decoration:none}
.logo-top{font-size:13px;color:var(--ink);display:block}
.logo-bot{font-family:var(--fd);font-size:36px;font-weight:800;letter-spacing:-.04em;line-height:.9;text-transform:uppercase;display:block;color:var(--ink)}
.logo-bot span{color:var(--blue)}
.nav-r{display:flex;align-items:center;gap:32px}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links li{font-size:14px;opacity:.6;cursor:pointer;transition:opacity .15s}
.nav-links li:hover{opacity:1}
.nav-links li.on{opacity:1;font-weight:500}
.cta{font-family:var(--fd);font-size:13px;font-weight:600;background:var(--blue);color:#fff;padding:11px 24px;border-radius:100px;border:none;cursor:pointer;transition:opacity .15s;text-decoration:none;display:inline-block}
.cta:hover{opacity:.85}

/* UTILS */
.divider{height:1px;background:rgba(0,0,0,.1);margin:0 48px}
.eyebrow{font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--orange);display:flex;align-items:center;gap:10px}
.eyebrow::before{content:'';width:20px;height:2px;background:var(--orange);border-radius:2px;display:inline-block}
.ctag{font-size:10px;font-weight:500;padding:4px 12px;border-radius:100px;border:1.5px solid rgba(0,0,0,.1);color:var(--muted);background:transparent}
.ctag.b{background:#EEF2FF;border-color:var(--blue);color:var(--blue)}
.ctag.o{background:#FFF0E8;border-color:var(--orange);color:var(--orange)}
.ctag.r{background:#F9F0F7;border-color:var(--rose);color:#8B5A7A}
.last-updated{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:500;padding:5px 14px;border-radius:100px;background:rgba(0,0,0,.05);color:var(--muted)}
.last-updated::before{content:'';width:6px;height:6px;border-radius:50%;background:#22C55E;display:inline-block}

/* STATS STRIP */
.stats{display:grid;grid-template-columns:repeat(4,1fr);padding:0 48px}
.stat{padding:40px 32px;border-right:1px solid rgba(0,0,0,.08)}
.stat:last-child{border-right:none}
.stat-n{font-family:var(--fd);font-size:64px;font-weight:500;letter-spacing:-.04em;line-height:1;text-transform:lowercase;margin-bottom:8px}
.stat-l{font-size:13px;color:var(--muted);font-weight:300;line-height:1.5;max-width:180px}

/* SECTION */
.sec{padding:56px 48px;border-top:1px solid rgba(0,0,0,.08)}
.sec-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:36px}
.sec-title{font-family:var(--fd);font-size:clamp(28px,3.5vw,48px);font-weight:500;text-transform:lowercase;letter-spacing:-.03em;line-height:1}

/* CARDS GRID 3 COL */
.card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.card{background:var(--white);padding:32px;position:relative;overflow:hidden;transition:background .15s}
.card:hover{background:#F4F5F8}
.card:nth-child(1){border-radius:16px 0 0 16px}
.card:nth-child(3){border-radius:0 16px 16px 0}
.card-ghost-num{font-family:var(--fd);font-size:88px;font-weight:800;letter-spacing:-.06em;line-height:1;color:rgba(0,0,0,.04);position:absolute;right:-4px;top:4px;pointer-events:none;user-select:none}
.card-eyebrow{font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.card-title{font-family:var(--fd);font-size:17px;font-weight:500;text-transform:lowercase;letter-spacing:-.02em;margin-bottom:10px;line-height:1.2}
.card-body{font-size:13px;color:var(--muted);font-weight:300;line-height:1.75}
.card-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:18px}

/* INFO ROWS (2 col layout) */
.info-layout{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.info-block{background:var(--white);padding:36px 40px}
.info-block:first-child{border-radius:16px 0 0 16px}
.info-block:last-child{border-radius:0 16px 16px 0}
.info-label{font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
.info-val{font-family:var(--fd);font-size:22px;font-weight:500;letter-spacing:-.03em;line-height:1.15;margin-bottom:6px}
.info-sub{font-size:13px;color:var(--muted);font-weight:300;line-height:1.7}
.info-link{font-size:13px;color:var(--blue);font-weight:500;display:inline-flex;align-items:center;gap:6px;margin-top:10px;transition:opacity .15s}
.info-link:hover{opacity:.7}

/* HIGHLIGHT */
.highlight{border-left:3px solid var(--blue-lt);padding:14px 20px;border-radius:0 10px 10px 0;background:rgba(0,33,188,.03);font-size:14px;line-height:1.75;color:#3A3D6B}
.highlight.orange{border-left-color:var(--orange);background:#FFF8F4;color:#7A3A1A}

/* ACCORDION */
.acc-item{border-bottom:1px solid rgba(0,0,0,.07)}
.acc-item:first-child{border-top:1px solid rgba(0,0,0,.07)}
.acc-btn{width:100%;display:flex;justify-content:space-between;align-items:center;padding:22px 0;cursor:pointer;background:none;border:none;font-family:var(--fd);font-size:16px;font-weight:500;text-transform:lowercase;letter-spacing:-.01em;color:var(--ink);text-align:left;gap:16px;transition:color .15s}
.acc-btn:hover{color:var(--blue)}
.acc-btn.open{color:var(--blue)}
.acc-arrow{width:28px;height:28px;border-radius:50%;background:rgba(0,0,0,.06);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;transition:transform .2s,background .15s}
.acc-btn.open .acc-arrow{transform:rotate(180deg);background:var(--blue);color:#fff}
.acc-body{display:none;padding-bottom:22px;font-size:13px;color:var(--muted);font-weight:300;line-height:1.8;max-width:640px}
.acc-body.open{display:block}

/* BIG QUOTE */
.big-quote{font-family:var(--fd);font-size:clamp(32px,4vw,56px);font-weight:500;letter-spacing:-.03em;line-height:1.1;text-transform:lowercase}

/* TABLE RESPONSABLES */
.resp-table{width:100%;border-collapse:collapse}
.resp-table th{font-size:10px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);text-align:left;padding:12px 20px;border-bottom:1px solid rgba(0,0,0,.08);background:rgba(0,0,0,.02)}
.resp-table td{padding:20px;font-size:13px;font-weight:300;color:var(--ink);border-bottom:1px solid rgba(0,0,0,.04);vertical-align:top;line-height:1.6}
.resp-table tr:last-child td{border-bottom:none}
.resp-table tr:hover td{background:rgba(0,33,188,.02)}
.resp-table td strong{font-weight:500;display:block;font-family:var(--fd);font-size:15px;letter-spacing:-.01em;margin-bottom:2px}
.resp-table .td-link{color:var(--blue);font-weight:500;font-size:12px}

/* CONTACT BANNER */
.contact-banner{background:var(--blue);border-radius:20px;padding:48px;display:grid;grid-template-columns:1fr auto;align-items:center;gap:40px;margin:0 48px 56px}
.contact-banner-title{font-family:var(--fd);font-size:clamp(28px,3vw,44px);font-weight:500;letter-spacing:-.04em;text-transform:lowercase;color:#fff;line-height:1;margin-bottom:12px}
.contact-banner-sub{font-size:14px;color:rgba(255,255,255,.55);font-weight:300;line-height:1.65;max-width:440px;border-left:3px solid rgba(255,255,255,.2);padding-left:16px}
.contact-btn{font-family:var(--fd);font-size:13px;font-weight:600;background:var(--orange);color:#fff;padding:14px 32px;border-radius:100px;border:none;cursor:pointer;white-space:nowrap;text-transform:lowercase;transition:opacity .15s;display:inline-block}
.contact-btn:hover{opacity:.85}

/* SOMMAIRE STICKY */
.sommaire{background:var(--white);border-radius:14px;padding:24px 28px;margin:0 48px 0}
.sommaire-title{font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.sommaire-links{display:flex;flex-wrap:wrap;gap:8px}
.sommaire-link{font-size:13px;font-weight:400;color:var(--ink);padding:6px 16px;border-radius:100px;border:1.5px solid rgba(0,0,0,.1);transition:all .15s;cursor:pointer}
.sommaire-link:hover{background:var(--blue);border-color:var(--blue);color:#fff}

/* FOOTER */
.footer-top{padding:48px 48px 36px;display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:40px;border-top:1px solid rgba(0,0,0,.08)}
.footer-logo-bot{font-family:var(--fd);font-size:26px;font-weight:800;letter-spacing:-.04em;text-transform:uppercase;line-height:.95;margin-bottom:12px;color:var(--ink)}
.footer-logo-bot span{color:var(--blue)}
.footer-desc{font-size:12px;color:var(--muted);font-weight:300;line-height:1.65}
.footer-col-title{font-size:11px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-links li{font-size:13px;color:rgba(0,0,0,.45);cursor:pointer;font-weight:300;transition:color .15s}
.footer-links li:hover{color:var(--ink)}
.footer-links li.on{color:var(--blue);font-weight:500}
.footer-email-wrap{padding:0 48px;border-top:1px solid rgba(0,0,0,.08);display:flex;align-items:center;gap:16px}
.footer-email{font-family:var(--fd);font-size:clamp(24px,4vw,56px);font-weight:500;color:var(--ink);letter-spacing:-.04em;text-transform:lowercase;padding:28px 0;text-decoration:none;transition:color .15s}
.footer-email:hover{color:var(--blue)}
.footer-bar{background:var(--blue);padding:16px 48px;display:flex;justify-content:space-between;align-items:center}
.footer-bar-links{display:flex;gap:40px}
.footer-bar-links a{font-size:13px;font-weight:500;color:rgba(255,255,255,.7);text-decoration:none;cursor:pointer;transition:color .15s}
.footer-bar-links a:hover{color:#fff}
.footer-bar-copy{font-size:12px;color:rgba(255,255,255,.35)}
</style>
</head>
