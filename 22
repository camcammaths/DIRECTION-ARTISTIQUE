function saveBrevet(){
  const note=parseFloat(document.getElementById('f-note').value);
  if(isNaN(note)||note<0||note>20){alert('Note invalide');return;}
  const dateRaw=document.getElementById('f-date').value,date=dateRaw?new Date(dateRaw).toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'}):editIdx!==null?sessions[editIdx].date:new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'});
  const notions=document.getElementById('f-notions').value.trim(),comment=document.getElementById('f-comment').value.trim(),exos=[];
  document.querySelectorAll('#f-exos-list > div').forEach(row=>{const nom=row.querySelector('.exo-nom').value.trim(),earned=parseFloat(row.querySelector('.exo-earned').value),max=parseFloat(row.querySelector('.exo-max').value);if(nom&&!isNaN(earned)&&!isNaN(max))exos.push({nom,earned,max});});
  const prevUnlocked=getUnlocked().map(b=>b.id);
  if(editIdx!==null)sessions[editIdx]={...sessions[editIdx],date,note,notions,comment,exos};
  else sessions.unshift({date,note,notions,comment,exos,conseils:[]});
  save();closeModal('modal-bg');renderAll();
  const newBadges=getUnlocked().filter(b=>!prevUnlocked.includes(b.id));
  if(newBadges.length){setTimeout(()=>{confetti();showToast(`🏆 Badge débloqué : ${newBadges[0].name} ${newBadges[0].icon}`);},300);}
  else showToast(editIdx===null?'✓ Brevet enregistré':'✓ Brevet modifié');
  if(editIdx===null)setTimeout(()=>{toggleRow(0);},200);
}
