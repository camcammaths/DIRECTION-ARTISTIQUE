      </div>`:''}
      <div style="margin-top:20px;display:flex;gap:10px;align-items:center">
        <span style="font-size:12px;color:var(--green);font-weight:600">✓ ajouté à mon parcours</span>
        <button onclick="fermerBrevet();goTo('parcours')" style="font-family:var(--fd);font-size:13px;font-weight:600;padding:11px 24px;border-radius:100px;border:none;background:var(--blue);color:#fff;cursor:pointer">voir mon parcours →</button>
        <button onclick="fermerBrevet()" style="font-family:var(--fd);font-size:13px;font-weight:600;padding:11px 24px;border-radius:100px;border:1.5px solid rgba(0,0,0,.12);background:transparent;cursor:pointer">fermer</button>
