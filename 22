  window._bilanData={note,label,exScores,corrections,totalEarned,totalPts};
  sauvegarderBilanParcours();
}

function sauvegarderBilanParcours(){
  const d=window._bilanData;
  if(!d)return;
  const date=new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'});
  const notions=[...new Set(window._brevetData.map(e=>e.notion))].join(', ');
  const exos=d.exScores.map(s=>({nom:s.titre,earned:s.earned,max:s.max}));
  const commentaires=d.corrections.map(c=>c.qId+'. '+c.comment).filter(Boolean).slice(0,5);

  sessions.unshift({date,note:d.note,mention:d.label,notions,exos,commentaires,conseils:commentaires});
  localStorage.setItem('pb_da2_sessions',JSON.stringify(sessions));
  showToast('✓ Brevet ajouté au parcours !');
  document.querySelector('#brevet-bilan button[onclick="sauvegarderBilanParcours()"]').textContent='✓ ajouté';
  document.querySelector('#brevet-bilan button[onclick="sauvegarderBilanParcours()"]').disabled=true;
}

