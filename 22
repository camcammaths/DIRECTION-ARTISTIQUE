function goTo(page){
  document.querySelectorAll('.page').forEach(p=>{p.style.display='none';p.classList.remove('active');});
  var target=document.getElementById('page-'+page);
  target.classList.add('active');
  if(page==='parcours'){target.style.display='flex';target.style.flexDirection='column';target.style.height='calc(100vh - 93px)';target.style.overflow='hidden';}
  else if(page==='abonnement'){target.style.display='flex';target.style.flexDirection='column';target.style.height='calc(100vh - 93px)';target.style.overflow='hidden';}
  else if(page==='planning'){target.style.display='flex';target.style.flexDirection='column';target.style.height='calc(100vh - 93px)';target.style.overflow='hidden';setTimeout(()=>renderPlanning(),50);}
  else if(page==='generer'){target.style.display='flex';target.style.flexDirection='column';target.style.height='calc(100vh - 93px)';target.style.overflow='hidden';}
  else{target.style.display='block';}
  document.querySelectorAll('.nav-links li').forEach(li=>{li.classList.remove('on','on-orange');if(li.dataset.page==='abonnement')li.classList.add('on-orange');else if(li.dataset.page===page)li.classList.add('on');});
  window.scrollTo(0,0);
  if(page==='parcours') renderAll();
}

